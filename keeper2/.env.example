# Copy this file to keeper2/.env and fill in your values
# NEVER commit keeper2/.env to git -- it holds real signing authority over
# whatever capital you send this wallet.

# Private key of ERZA's wallet (fund it with native ETH; WETH wraps on demand).
# Generate a FRESH wallet for this -- don't reuse a wallet holding anything else.
KEEPER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional: use a faster/private RPC to reduce latency and avoid rate limits.
# Put the dedicated Alchemy HTTPS endpoint here.
RPC_URL=https://rpc.mainnet.chain.robinhood.com

# Optional low-latency block wake-up. If RPC_URLS contains an Alchemy HTTPS
# endpoint, the keeper derives its WSS twin automatically; setting this is
# still recommended so the intent is explicit. HTTP reads/log backfill stay
# authoritative, and are polled automatically if WebSocket delivery stalls.
WS_RPC_URL=
WEBSOCKET_SCANNING=true
WS_FALLBACK_POLL_MS=3000
WS_RECONNECT_BASE_MS=1000
WS_RECONNECT_MAX_MS=300000

# Signed raw transactions bypass the read provider and go directly to the
# first-come-first-served Robinhood sequencer. Keep this default.
SUBMIT_RPC_URL=https://sequencer.mainnet.chain.robinhood.com

# ERZA hard-enforces WETH-only external-first behavior. Pure AEON-only cycles
# are excluded; mixed routes may use an AEON hop behind external opportunities.
KEEPER_ROLE=external-first
BOT_ID=aeon

# Optional comma-separated additional endpoints. The keeper automatically
# fails over across this list and RPC_URL. Put the dedicated Alchemy endpoint
# first and keep the official Robinhood RPC as the fallback.
RPC_URLS=

# Never size a candidate to literally 100% of its settlement-token balance.
# 9900 = use at most 99%, leaving rounding/dust headroom.
MAX_BALANCE_USAGE_BPS=9900

# Cool down only a repeatedly failing route while every other route keeps
# scanning/executing. Cooldowns double on repeated route-local failures.
ROUTE_FAILURE_THRESHOLD=2
ROUTE_COOLDOWN_MS=60000
ROUTE_MAX_COOLDOWN_MS=900000
STALE_QUOTE_RETRY_MS=1000
PENDING_TX_TIMEOUT_MS=6000
REPLACEMENT_GAS_BUMP_BPS=1250
TX_FEE_HEADROOM_BPS=20000

# Minimum quoted profit percentage considered. Zero means every positive
# quote is considered; execution still requires profit to exceed the
# buffered gas estimate, even if the remaining net profit is extremely small.
MIN_PROFIT_PCT=0

# Every ERZA cycle starts and ends in WETH. Other configured tokens may be
# intermediate hops, but can never be the settlement asset.
BASE_TOKEN=WETH

# Max hops per cycle. Hop count itself doesn't matter -- only whether the
# cycle clears gas after all those hops' fees -- but each extra hop is more
# fee drag to overcome, so very deep cycles rarely clear it in practice.
# Hard-capped at 16 regardless of this value.
MAX_HOPS=5

# Exhaustive route-shape safety ceiling per settlement token. Exposed here so
# coverage can be audited instead of relying on a hidden code default.
MAX_DFS_VISITS=200000

# Safety invariant: every arbitrage starts and ends in the same token. The
# keeper enforces this in code as well, so a stale deployment config cannot
# accidentally enable cross-settlement valuation.
SAME_TOKEN_ONLY=true
ATOMIC_ONLY=true

# How often (ms) ERZA refreshes the reachable Robinhood Uniswap token graph.
# Discovery validates canonical V2/V3/V4 pools before making them executable.
# It only adds pools not already known; it never duplicates existing entries.
POOL_REFRESH_INTERVAL_MS=600000

# ERZA's broad graph relies on pool-event updates between periodic safety
# refreshes. These intervals prevent a large full scan from immediately
# triggering another full scan before the previous one has finished.
FULL_STATE_REFRESH_MS=120000
GAS_ONLY_RECHECK_MS=120000

# Chain-wide external discovery controls. There is intentionally no 24-hour
# volume gate: quiet pools can still be mispriced. The small liquidity floor
# prevents dust/spam pools from making the graph unbounded. Increase depth or
# caps only if the RPC/API plan has enough throughput for a larger refresh.
EXTERNAL_MIN_LIQUIDITY_USD=1000
EXTERNAL_DISCOVERY_DEPTH=2
EXTERNAL_DISCOVERY_MAX_TOKENS=300
EXTERNAL_DISCOVERY_MAX_POOLS=1200
DEXSCREENER_REQUEST_GAP_MS=220

# Exact quoting is deliberately less bursty than approximate graph scanning.
# Two concurrent routes keeps the dedicated RPC responsive while rotating
# quote slots across distinct token families.
EXACT_QUOTE_CANDIDATES=12
EXACT_QUOTE_MAX_ATTEMPTS=36
EXACT_QUOTE_CONCURRENCY=2

# Native ETH isn't one of the pool tokens (everything trades WETH), but it's
# economically fungible with WETH via wrap/unwrap -- whatever's spare above
# this amount counts as WETH capacity for discovery/sizing and gets wrapped
# on demand right before a trade that needs it. This amount is NEVER
# touched by trading. If native ETH drops below it, the keeper unwraps WETH
# 1:1 to restore the reserve and continues instead of disabling execution.
GAS_RESERVE_ETH=0.002
GAS_REFILL_TARGET_BPS=12000
GAS_REFILL_RETRY_MS=30000

# Require a fresh exact gas estimate plus a small inclusion-time margin.
# Values below 100 are clamped so a route can never ignore estimated gas.
GAS_SAFETY_MULT_PCT=105

# Poll interval in milliseconds. 1000 = every second, as requested -- if your
# RPC starts throwing rate-limit errors, raise this.
INTERVAL_MS=1000

# Set to "true" to scan and log opportunities without ever sending a transaction
DRY_RUN=false

# Cross-venue arb (our pools vs. OpenOcean / 1inch) scan interval in ms.
# Runs much less often than INTERVAL_MS on purpose -- it costs real API
# calls, unlike the internal scan which is pure RPC reads. Raise this if
# you hit rate limits.
AGGREGATOR_SCAN_INTERVAL_MS=30000

# The optional rate-limited aggregator fallback derives eligible intermediate
# tokens from Mirajane's live external pool graph. This limits each request
# wave while rotating through every connected token over successive scans.
EXTERNAL_ARB_CANDIDATES_PER_SCAN=4

# Slippage tolerance (%) passed to the aggregator when requesting swap calldata
AGGREGATOR_SLIPPAGE_PCT=0.5

# Cross-venue execution is non-atomic and can leave an intermediate token in
# the wallet. Keep disabled until both legs are supported by one executor.
ENABLE_CROSS_VENUE=false

# Pause live execution after repeated failures, while scanning continues.
MAX_CONSECUTIVE_FAILURES=3
FAILURE_PAUSE_MS=300000

# Optional: 1inch API key from portal.1inch.dev, for the cross-venue scan.
# Deliberately separate from the frontend's own ONEINCH_API_KEY in
# .env.local -- keeps the bot's request volume off the swap page's budget.
# Leave blank to run on OpenOcean only (no key needed, works out of the box).
ONEINCH_API_KEY=
ONEINCH_API_BASE=

# Optional: shared Upstash Redis store (src/lib/botStore.ts) -- only needed
# if this bot runs on a DIFFERENT machine than the website (e.g. bot here,
# website on Vercel). Without these, the bot only writes status.json/
# trades.log locally, and the website can only read them if it's running on
# this same machine. With these set, the bot also pushes status (throttled,
# see REDIS_STATUS_SYNC_INTERVAL_MS) and every trade to Redis, and the
# website's /api/bot/* routes read from there instead. Get these values from
# your Vercel project's Storage tab -> your KV/Upstash database -> the
# ".env.local" quickstart tab (same values Vercel injects into the site's
# own deployment automatically -- copy them here too for the bot side).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# How often (ms) the bot pushes its status snapshot to the shared store.
# Trades sync immediately regardless of this -- only the fast-changing
# status snapshot is throttled, to stay within Upstash's free-tier budget.
REDIS_STATUS_SYNC_INTERVAL_MS=15000
