# Copy this file to keeper/.env and fill in your values
# NEVER commit keeper/.env to git -- it holds real signing authority over
# whatever capital you send this wallet.

# Private key of the keeper wallet (fund it with AEON/USDG/WETH/etc. to arb with).
# Generate a FRESH wallet for this -- don't reuse a wallet holding anything else.
KEEPER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional: use a faster/private RPC to reduce latency and avoid rate limits
RPC_URL=https://rpc.mainnet.chain.robinhood.com

# Optional comma-separated additional endpoints. The keeper automatically
# fails over across this list, RPC_URL, and its verified Blockscout proxy.
# Put a private QuickNode endpoint first here when available.
RPC_URLS=

# Never size a candidate to literally 100% of its settlement-token balance.
# 9900 = use at most 99%, leaving rounding/dust headroom.
MAX_BALANCE_USAGE_BPS=9900

# Cool down only a repeatedly failing route while every other route keeps
# scanning/executing. Cooldowns double on repeated route-local failures.
ROUTE_FAILURE_THRESHOLD=2
ROUTE_COOLDOWN_MS=60000
ROUTE_MAX_COOLDOWN_MS=900000

# Minimum quoted profit percentage considered. Zero means every positive
# quote is considered; execution still requires profit to exceed the
# buffered gas estimate, even if the remaining net profit is extremely small.
MIN_PROFIT_PCT=0

# Every cycle starts AND ends in the SAME token. Leave blank (default) to
# auto-discover every token the wallet holds above a dust floor each tick
# and search a cycle anchored at each one -- it doesn't have to be USDG, or
# any one fixed token, all that matters is ending up in profit. Set this to
# pin the search to just one token instead.
BASE_TOKEN=

# Max hops per cycle. Hop count itself doesn't matter -- only whether the
# cycle clears gas after all those hops' fees -- but each extra hop is more
# fee drag to overcome, so very deep cycles rarely clear it in practice.
# Hard-capped at 16 regardless of this value.
MAX_HOPS=12

# Hard safety invariants. Keep both true for the production keeper:
# every arbitrage must finish in its starting token, and every executable
# route must settle all legs in one transaction.
SAME_TOKEN_ONLY=true
ATOMIC_ONLY=true

# How often (ms) the bot re-scans for newly-qualifying pools/tokens (Uniswap
# V2, AEON's own CL/DLMM, high-volume Uniswap V3) instead of only ever
# discovering them once at startup. Idempotent -- a refresh only adds pools
# not already known, never restarts or duplicates existing ones.
POOL_REFRESH_INTERVAL_MS=600000

# Native ETH isn't one of the pool tokens (everything trades WETH), but it's
# economically fungible with WETH via wrap/unwrap -- whatever's spare above
# this amount counts as WETH capacity for discovery/sizing and gets wrapped
# on demand right before a trade that needs it. This amount is NEVER
# touched, so the bot can always pay for its own future transactions.
GAS_RESERVE_ETH=0.005

# Poll interval in milliseconds. 1000 = every second, as requested -- if your
# RPC starts throwing rate-limit errors, raise this.
INTERVAL_MS=1000

# Set to "true" to scan and log opportunities without ever sending a transaction
DRY_RUN=false

# Cross-venue arb (our pools vs. OpenOcean / 1inch) scan interval in ms.
# Runs much less often than INTERVAL_MS on purpose -- it costs real API
# calls, unlike the internal scan which is pure RPC reads. Raise this if
# you hit rate limits.
AGGREGATOR_SCAN_INTERVAL_MS=30000

# Slippage tolerance (%) passed to the aggregator when requesting swap calldata
AGGREGATOR_SLIPPAGE_PCT=0.5

# Cross-venue execution is non-atomic and can leave an intermediate token in
# the wallet. Keep disabled until both legs are supported by one executor.
ENABLE_CROSS_VENUE=false

# Pause live execution after repeated failures, while scanning continues.
MAX_CONSECUTIVE_FAILURES=3
FAILURE_PAUSE_MS=300000

# Optional: 1inch API key from portal.1inch.dev, for the cross-venue scan.
# Deliberately separate from the frontend's own ONEINCH_API_KEY in
# .env.local -- keeps the bot's request volume off the swap page's budget.
# Leave blank to run on OpenOcean only (no key needed, works out of the box).
ONEINCH_API_KEY=
ONEINCH_API_BASE=

# Optional: shared Upstash Redis store (src/lib/botStore.ts) -- only needed
# if this bot runs on a DIFFERENT machine than the website (e.g. bot here,
# website on Vercel). Without these, the bot only writes status.json/
# trades.log locally, and the website can only read them if it's running on
# this same machine. With these set, the bot also pushes status (throttled,
# see REDIS_STATUS_SYNC_INTERVAL_MS) and every trade to Redis, and the
# website's /api/bot/* routes read from there instead. Get these values from
# your Vercel project's Storage tab -> your KV/Upstash database -> the
# ".env.local" quickstart tab (same values Vercel injects into the site's
# own deployment automatically -- copy them here too for the bot side).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# How often (ms) the bot pushes its status snapshot to the shared store.
# Trades sync immediately regardless of this -- only the fast-changing
# status snapshot is throttled, to stay within Upstash's free-tier budget.
REDIS_STATUS_SYNC_INTERVAL_MS=15000
