# Copy this file to keeper/.env and fill in your values
# NEVER commit keeper/.env to git

# Private key of the keeper wallet (must hold AEON, USDG, WETH to arb with)
KEEPER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional: use a faster/private RPC to reduce latency
RPC_URL=https://rpc.mainnet.chain.robinhood.com

# Minimum profit in % before executing (default: 0.1)
MIN_PROFIT_USD=0.05

# Poll interval in milliseconds (default: 5000)
INTERVAL_MS=5000

# Set to "true" to simulate without sending transactions
DRY_RUN=false
