# To let the bot TRADE (not just detect), copy this to `.env` and fill in:
#
#   1. BOT_PK  -- private key of the bot's OWN funded wallet (starts with 0x).
#                 Fund it with WETH (trading capital) + a little ETH (gas).
#                 Never share this key. The bot reads it but never logs it.
#   2. DRY_RUN=false  -- flip this ONLY when you want it to place real trades.
#
# Trades are atomic (single Uniswap V3 multi-hop) with an on-chain minimum-out
# floor, so a bad/moved price just reverts and you lose only gas.

BOT_PK=
DRY_RUN=true
# Optional: minimum net profit in WETH before it fires (default 0.0002)
# MIN_PROFIT_WETH=0.0002
