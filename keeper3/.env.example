# === THE ONLY THING YOU NEED TO DO ===
# Copy this file to `.env` and paste your bot wallet's private key below.
# That's it -- with a key present the bot trades automatically. With no key it
# stays in safe detect-only mode.
#
# (Make sure that wallet holds WETH = trading capital, plus a little ETH for
#  gas. The bot approves WETH itself. Trades are atomic and revert if the price
#  moves, so the worst case is gas.)

BOT_PK=

# --- optional, leave alone unless you know you want them ---
# DRY_RUN=true            # force detect-only even with a key set
# MIN_PROFIT_WETH=0.0002  # minimum net profit before it fires
