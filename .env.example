# Server-only key that signs Tower Defense reward attestations.
# Holds no funds -- only its address matters on-chain (AeonTowerDefenseArena's
# trustedSigner). Never the deployer/treasury key. Generate with:
#   cast wallet new
TOWER_DEFENSE_SIGNER_PK=0xyourprivatekeyhere

# 1inch Swap API key -- required to fetch quotes/swap calldata from their
# aggregator. Get one at https://portal.1inch.dev (free tier available).
# Without this set, the swap page silently skips 1inch and falls back to our
# own routing -- no crash, just missing that extra venue.
ONEINCH_API_KEY=
# Override only if your plan uses a different API host than the default.
ONEINCH_API_BASE=https://api.1inch.dev
