  "poolTypes": [
    {
      "type": "vAMM",
      "description": "Constant product x*y=k AMM. UniswapV2-compatible interface.",
      "feeEncoding": "feeBps as uint24 (e.g. 30 = 0.3%)",
      "swapFunction": "swap(uint256 amount0Out, uint256 amount1Out, address to, bytes calldata data)",
      "getReserves": "getReserves() returns (uint112 reserve0, uint112 reserve1, uint32 blockTimestampLast)",
      "token0": "token0() returns (address)",
      "token1": "token1() returns (address)"
    }
  ],
  "swapMath": {
    "formula": "amountOut = (amountIn * (10000 - feeBps) * reserveOut) / (reserveIn * 10000 + amountIn * (10000 - feeBps))",
    "feeRange": "1 to 100 bps (0.01% to 1%)"
  },
